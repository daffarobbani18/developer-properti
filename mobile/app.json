{
  "expo": {
    "name": "SIMDP Mobile",
    "slug": "simdp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e5f1f0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.simdp.mobile",
      "buildNumber": "1.0.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#e5f1f0"
      },
      "package": "com.simdp.mobile",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/icon.png",
      "description": "SIMDP Mobile - Sistem Informasi Manajemen Developer Perumahan"
    },
    "extra": {
      "eas": {
        "projectId": "simdp-mobile-project"
      }
    },
    "plugins": [
      "@sentry/react-native"
    ]
  }
}
