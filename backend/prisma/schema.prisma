generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., 'Admin Inventory', 'Sales', 'Finance'
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  constructionProgresses ConstructionProgress[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id              String         @id @default(uuid())
  name            String
  location        String
  totalUnits      Int            @default(0)
  targetSelesai   DateTime?
  status          String         @default("perencanaan") // perencanaan, konstruksi, finishing, selesai
  
  propertyTypes   PropertyType[]
  units           Unit[]
  sitePlans       SitePlan[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PropertyType {
  id              String         @id @default(uuid())
  projectId       String
  name            String
  luasTanah       Float
  luasBangunan    Float
  bedrooms        Int            // Lama
  bathrooms       Int            // Lama
  price           Float          // Lama
  imageUrl        String?        
  
  // Field Baru (Fase 2)
  kamarTidur      Int            @default(0)
  kamarMandi      Int            @default(0)
  basePrice       Float          @default(0)
  
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  units           Unit[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Unit {
  id              String         @id @default(uuid())
  projectId       String
  propertyTypeId  String
  blok            String         // Lama dan Baru
  nomorUnit       String         // Lama
  price           Float          // Lama
  status          String         @default("Tersedia") // Lama
  
  // Field Baru (Fase 2)
  kawasan         String         @default("Area 1")
  nomor           String         @default("")
  statusPembangunan String       @default("Pesan Bangun") // Pesan Bangun, Siap Huni
  statusPenjualan String         @default("Tersedia") // Tersedia, Booked, Terjual
  priceMarkup     Float          @default(0)
  totalPrice      Float          @default(0)
  
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  propertyType    PropertyType   @relation(fields: [propertyTypeId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  constructionProgresses ConstructionProgress[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model SitePlan {
  id              String         @id @default(uuid())
  projectId       String
  imageUrl        String
  coordinatesData String         @default("{}") // JSON string for SVG/JSON coordinates
  
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Lead {
  id          String    @id @default(uuid())
  name        String
  phone       String
  email       String?
  source      String
  statusCrm   String    @default("New")
  notes       String?
  
  bookings    Booking[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id             String    @id @default(uuid())
  leadId         String
  unitId         String
  bookingFee     Float
  paymentMethod  String
  status         String    @default("Menunggu Verifikasi")
  
  // Field Baru (Fase 4 - Finance)
  verifiedAt     DateTime?
  receiptUrl     String?
  financeNotes   String?
  
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Restrict)
  unit           Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  
  invoices       Invoice[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Invoice {
  id              String    @id @default(uuid())
  bookingId       String
  invoiceNumber   String    @unique
  invoiceType     String    // e.g., 'DP', 'Cicilan KPR', 'Cash Bertahap'
  amountDue       Float
  dueDate         DateTime
  status          String    @default("Unpaid")
  
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payments        Payment[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Payment {
  id              String    @id @default(uuid())
  invoiceId       String
  amountPaid      Float
  paymentDate     DateTime
  paymentMethod   String
  referenceNumber String?
  status          String    @default("Verified")
  
  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ConstructionProgress {
  id              String    @id @default(uuid())
  unitId          String
  percentage      Int
  description     String
  photoUrl        String?
  recordedAt      DateTime  @default(now())
  recordedById    String
  
  unit            Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  recordedBy      User      @relation(fields: [recordedById], references: [id], onDelete: Restrict)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
