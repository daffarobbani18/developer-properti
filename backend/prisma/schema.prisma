generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., 'Admin Inventory', 'Sales', 'Finance'
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  constructionProgresses ConstructionProgress[]
  commissions Commission[]
  activities  Activity[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id              String         @id @default(uuid())
  name            String
  location        String
  totalUnits      Int            @default(0)
  targetSelesai   DateTime?
  status          String         @default("perencanaan") // perencanaan, konstruksi, finishing, selesai
  jumlahKontraktor Int           @default(0)
  nilaiKontrak    Float          @default(0)
  
  // Field Baru (Fase 5 - Relational Inventory)
  kontraktorName  String?
  nomorIzin       String?
  description     String?        // "Tentang Proyek" (ditampilkan di halaman detail proyek di portal publik)
  imageUrl        String?
  
  propertyTypes   PropertyType[]
  units           Unit[]
  sitePlans       SitePlan[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PropertyType {
  id              String         @id @default(uuid())
  projectId       String
  name            String
  luasTanah       Float
  luasBangunan    Float
  bedrooms        Int            // Lama
  bathrooms       Int            // Lama
  price           Float          // Lama
  imageUrl        String?        
  
  // Field Baru (Fase 2)
  kamarTidur      Int            @default(0)
  kamarMandi      Int            @default(0)
  basePrice       Float          @default(0)
  estimasiRab     Decimal        @default(0)
  
  // Field Publik (tampil di Web Public Portal)
  facilities      String?        // Fasilitas & Keunggulan (ditampilkan di halaman detail tipe rumah di portal publik)
  
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  units           Unit[]
  milestoneTemplates MilestoneTemplate[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Unit {
  id              String         @id @default(uuid())
  projectId       String
  propertyTypeId  String
  blok            String         // Lama dan Baru
  nomorUnit       String         // Lama
  price           Float          // Lama
  status          String         @default("Tersedia") // Lama
  
  // Field Baru (Fase 2)
  kawasan         String         @default("Area 1")
  nomor           String         @default("")
  statusPembangunan String       @default("Pesan Bangun") // Pesan Bangun, Siap Huni
  statusPenjualan String         @default("Tersedia") // Tersedia, Booked, Terjual
  priceMarkup     Float          @default(0)
  totalPrice      Float          @default(0)
  
  // Field Baru (Fase 5 - Relational Inventory)
  luasTanahAktual Float?
  svgPathId       String?        // Untuk SVG Mapping di Site Plan Publik
  spkId           String?
  
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  propertyType    PropertyType   @relation(fields: [propertyTypeId], references: [id], onDelete: Cascade)
  spk             Spk?           @relation(fields: [spkId], references: [id])
  bookings        Booking[]
  constructionProgresses ConstructionProgress[]
  milestones      Milestone[]
  
  progress        Int            @default(0) // Field Baru: Total Progres Bangunan (0 - 100)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model SitePlan {
  id              String         @id @default(uuid())
  projectId       String
  imageUrl        String
  coordinatesData String         @default("{}") // JSON string for SVG/JSON coordinates
  
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Lead {
  id          String    @id @default(uuid())
  nik         String?
  name        String
  phone       String
  email       String?
  address     String?
  source      String
  statusCrm   String    @default("New")
  notes       String?
  
  bookings    Booking[]
  activities  Activity[]

  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id             String    @id @default(uuid())
  leadId         String
  unitId         String
  bookingFee     Float
  paymentMethod  String
  status         String    @default("Menunggu Verifikasi")
  
  // Field Baru (Fase 4 - Finance & Sales Notes)
  verifiedAt     DateTime?
  receiptUrl     String?
  financeNotes   String?
  salesNotes     String?   // Catatan dari Sales (misal: "KPR 15 Tahun", "Cash Bertahap 12x")
  
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Restrict)
  unit           Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  
  invoices       Invoice[]
  expenses       Expense[]
  legalDocuments LegalDocument[]
  basts          Bast[]
  commissions    Commission[]
  kprApplication KprApplication?
  defects        DefectComplaint[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Spk {
  id              String         @id @default(uuid())
  spkNo           String         @unique
  date            DateTime
  contractorName  String
  totalPrice      Decimal
  totalDisbursed  Decimal        @default(0) // Akumulasi total dana yang dicairkan
  
  units           Unit[]
  expenses        Expense[]      // Pencatatan jurnal kas keluar untuk SPK ini
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Invoice {
  id              String    @id @default(uuid())
  bookingId       String
  invoiceNumber   String    @unique
  invoiceType     String    // e.g., 'DP', 'Cicilan KPR', 'Cash Bertahap'
  amountDue       Float
  dueDate         DateTime
  status          String    @default("Unpaid")
  
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payments        Payment[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Expense {
  id              String    @id @default(uuid())
  category        String    // e.g., 'Refund Pembatalan KPR', 'Material Proyek', 'Operasional'
  amount          Float
  description     String
  status          String    @default("Menunggu Transfer") // Menunggu Transfer, Sudah Ditransfer
  bookingId       String?   // Opsional, digunakan jika pengeluaran terkait dengan pembatalan klien
  spkId           String?   // Opsional, untuk kas keluar proyek (Kasbon/Termin Mandor)
  
  booking         Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  spk             Spk?      @relation(fields: [spkId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Payment {
  id              String    @id @default(uuid())
  invoiceId       String
  amountPaid      Float
  paymentDate     DateTime
  paymentMethod   String
  referenceNumber String?
  status          String    @default("Verified")
  
  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ConstructionProgress {
  id              String    @id @default(uuid())
  unitId          String
  percentage      Int
  description     String
  photoUrl        String?
  recordedAt      DateTime  @default(now())
  recordedById    String
  
  unit            Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  recordedBy      User      @relation(fields: [recordedById], references: [id], onDelete: Restrict)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model LegalDocument {
  id             String    @id @default(uuid())
  bookingId      String
  documentType   String    // cth: 'PPJB', 'AJB', 'SHM', 'IMB'
  status         String    @default("Diproses")
  fileUrl        String?
  issuedAt       DateTime?
  notes          String?
  
  booking        Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Bast {
  id             String    @id @default(uuid())
  bookingId      String
  handoverDate   DateTime
  status         String    @default("Dijadwalkan")
  documentUrl    String?
  remarks        String?
  
  booking        Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Commission {
  id              String    @id @default(uuid())
  bookingId       String
  salesUserId     String
  percentage      Float
  nominalAmount   Float
  status          String    @default("Pending") // Pending, Approved, Paid
  approvedAt      DateTime?
  disbursedAt     DateTime?
  notes           String?
  
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  salesUser       User      @relation(fields: [salesUserId], references: [id], onDelete: Restrict)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Activity {
  id          String    @id @default(uuid())
  leadId      String
  salesId     String    // Relasi ke User (Sales)
  title       String
  type        String    // Telepon, WhatsApp, Email, Survei Lokasi, Meeting, Lainnya
  date        DateTime  // Kapan aktivitas ini dijadwalkan / dilakukan
  status      String    @default("Pending") // Pending, Selesai, Batal
  notes       String?   // Catatan (misal hasil survei)
  
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sales       User      @relation(fields: [salesId], references: [id], onDelete: Restrict)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model KprApplication {
  id                String    @id @default(uuid())
  bookingId         String    @unique
  bankName          String?   // e.g., 'Bank BCA', 'Bank Mandiri'
  plafondPengajuan  Float     @default(0)
  plafondDisetujui  Float?    // Nominal SP3K
  
  // Pipeline Status KPR
  status            String    @default("Kumpul Berkas") 
  // Enum: "Kumpul Berkas", "BI Checking", "Wawancara Bank", "SP3K Terbit", "Siap Akad", "Selesai Akad"

  // Flag untuk Finance (Edge Case: Plafon Turun)
  isPlafonTurun     Boolean   @default(false)
  selisihPlafon     Float     @default(0) // Kekurangan bayar yang harus ditagih Finance
  
  notes             String?

  booking           Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  documents         KprDocument[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model KprDocument {
  id               String         @id @default(uuid())
  kprApplicationId String
  documentType     String         // e.g., 'KTP', 'NPWP', 'KK', 'Buku Nikah', 'Slip Gaji', 'Rekening Koran'
  fileUrl          String?
  status           String         @default("Pending") // Pending, Valid, Invalid
  notes            String?
  
  kprApplication   KprApplication @relation(fields: [kprApplicationId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model MilestoneTemplate {
  id               String       @id @default(uuid())
  propertyTypeId   String
  name             String
  category         String
  orderNo          Int
  bobotPersentase  Float        @default(0)

  propertyType     PropertyType @relation(fields: [propertyTypeId], references: [id], onDelete: Cascade)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Milestone {
  id          String    @id @default(uuid())
  unitId      String
  name        String
  category    String
  orderNo     Int
  targetDate      DateTime? // Dibuat opsional karena mungkin belum diketahui saat auto-generate
  actualDate      DateTime?
  status          String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  note            String?
  photoUrls       String[]  @default([])
  bobotPersentase Float     @default(0) // Disalin dari MilestoneTemplate saat generate
  
  unit            Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  logs            MilestoneLog[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model MilestoneLog {
  id          String    @id @default(uuid())
  milestoneId String
  status      String    
  note        String?
  photoUrls   String[]  @default([])
  reportedBy  String?   
  
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
}

model DefectComplaint {
  id          String    @id @default(uuid())
  bookingId   String
  description String
  photoUrl    String?
  status      String    @default("Dilaporkan") // Dilaporkan, Sedang Diperbaiki, Selesai
  reportedAt  DateTime  @default(now())
  resolvedAt  DateTime?

  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
